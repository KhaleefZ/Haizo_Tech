// ===========================================================================
// HaizoTech data model.
//
// PORTED VERBATIM from the live production schema, then extended ADDITIVELY.
//
// Rules that make the cutover reversible — do not break them before the
// 30-day post-cutover window closes:
//   • No renames. No drops. New columns are nullable or defaulted.
//   • REDESIGN.md's Lead/CaseStudy/BlogPost naming and ADMIN/EDITOR roles were a
//     sketch. The live database is canonical; renaming production tables to match
//     a document is risk with no user value.
//   • Because every change is additive, the OLD backend keeps running against
//     this schema — which is what makes "flip nginx back" a real rollback.
//
// Phase 1 ports the existing models as-is. Phase 2 adds Service/Testimonial/
// Industry, Phase 3 the notification rebuild, Phase 7 the chat models.
// ===========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  MANAGER
  DEV
}

enum InquiryStatus {
  NEW
  READ
  REPLIED
}

model User {
  id                   String         @id @default(uuid())
  email                String         @unique
  password             String
  name                 String
  role                 Role           @default(DEV)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  bio                  String?
  maintenanceMode      Boolean        @default(false)
  notificationsEnabled Boolean        @default(true)
  inviteToken          String?        @unique
  inviteTokenExpires   DateTime?
  avatarUrl            String?

  // Phase 3 (additive). Bumping this invalidates every outstanding access and
  // refresh token for the user at once — it is the claim we check on every
  // request, so it is how "log out everywhere" and a JWT_SECRET rotation both
  // work without a token blocklist. Defaulted, so existing rows need no backfill.
  tokenVersion         Int            @default(0)

  // Phase 5 (additive). Per-type notification opt-outs, e.g. {"task.assigned":false}.
  // The master switch stays `notificationsEnabled`; this refines it per type.
  notificationPrefs    Json?

  announcements Announcement[] @relation("AnnouncementAuthor")
  blogs         Blog[]         @relation("BlogAuthor")
  notifications Notification[] @relation("UserNotifications")
  tasks         Task[]         @relation("TaskAssignee")

  // Phase 7 (additive).
  conversationMemberships ConversationMember[] @relation("ConversationMemberships")
  messagesSent            Message[]            @relation("MessagesSent")
}

model Work {
  id          String   @id @default(uuid())
  title       String
  category    String
  description String
  imageUrls   String[]
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  liveUrl     String?

  // Phase 4b (additive). Nullable + unique so existing rows are backfilled
  // without a rewrite; a later migration tightens it to NOT NULL once every row
  // has one. Postgres allows multiple NULLs under a unique index, so this is safe.
  slug        String?  @unique

  @@index([published])
}

model WorkCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inquiry {
  id             String        @id @default(uuid())
  name           String
  email          String
  message        String
  status         InquiryStatus @default(NEW)
  submissionDate DateTime      @default(now())
  phone          String?
  service        String?

  @@index([status])
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  clientId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  budget      String?
  endDate     DateTime?
  progress    Int       @default(0)
  startDate   DateTime?
  status      String    @default("Planning")

  columns       Column[]
  client        Client?        @relation(fields: [clientId], references: [id])
  conversations Conversation[] // Phase 7 (additive) — project channels
}

model Column {
  id        String @id @default(uuid())
  name      String
  order     Int
  projectId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime?
  tags        String[]
  order       Int
  columnId    String
  assigneeId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  delayReason String?
  isCompleted Boolean   @default(false)
  priority    String    @default("Low")
  startDate   DateTime?

  subtasks Subtask[]
  assignee User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  column   Column    @relation(fields: [columnId], references: [id], onDelete: Cascade)
}

model Subtask {
  id     String  @id @default(uuid())
  title  String
  isDone Boolean @default(false)
  taskId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Client {
  id           String    @id @default(uuid())
  organization String
  contactName  String
  email        String?
  createdAt    DateTime  @default(now())
  projects     Project[]
}

model Blog {
  id        String   @id @default(uuid())
  title     String
  content   String
  authorId  String
  tags      String[]
  imageUrl  String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Phase 4b (additive) — see the note on Work.slug.
  slug      String?  @unique

  author User @relation("BlogAuthor", fields: [authorId], references: [id])

  @@index([published])
}

// NOTE (Phase 5): `type` is currently an untyped String and there is no link to
// the thing the notification is about, which is why notifications in the live
// admin cannot be clicked through. The rebuild replaces this with a
// NotificationType enum plus entityType/entityId and a precomputed `url`.
// Left as-is here so the port stays verbatim and the migration is a separate,
// reviewable step.
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Phase 5 (additive). `type` stays a String rather than converting to a Postgres
  // enum: the old backend still writes this column during cutover, and an enum
  // conversion would reject its values. The NotificationType UNION in
  // lib/notifications/catalogue.ts is the real source of truth, validated in code.
  actorId    String? // who caused it (null for system events)
  entityType String? // e.g. "inquiry", "task" — what it's about
  entityId   String?
  url        String? // precomputed deep link so the bell is a dumb <Link>
  groupKey   String? // collapse related notifications
  emailedAt  DateTime? // digest/eligibility bookkeeping

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  audience  String   @default("ALL")
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation("AnnouncementAuthor", fields: [authorId], references: [id])

  @@index([audience])
}

// Phase 5 (additive). An append-only audit trail of admin mutations, recorded by
// a post-response middleware. `actorName`/`entityLabel` are denormalised so the
// history survives the actor or entity being deleted — no FK to keep it durable.
model ActivityEvent {
  id          String   @id @default(uuid())
  actorId     String?
  actorName   String?
  action      String // created | updated | deleted
  entityType  String // service | project | task | ...
  entityId    String?
  entityLabel String?
  path        String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// Phase 6 (additive). First-party analytics: raw page-view events rolled up
// nightly into a per-day metric so the dashboard reads a small table, not the
// full event stream.
model PageView {
  id        String   @id @default(uuid())
  path      String
  referrer  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}

model MetricDaily {
  // One row per calendar day (date-only PK).
  date  DateTime @id @db.Date
  views Int      @default(0)
}

// Phase 6 (additive). Object-storage uploads. A row is created PENDING when a
// presigned URL is issued and flipped to READY once the client confirms the
// direct upload — so half-finished uploads are distinguishable from live files.
model Attachment {
  id           String   @id @default(uuid())
  key          String   @unique // object key in the bucket
  filename     String
  mimeType     String
  size         Int
  status       String   @default("PENDING") // PENDING | READY
  uploadedById String?
  createdAt    DateTime @default(now())

  // Phase 7 (additive). When set, this upload is an attachment on a chat message.
  messageId String?

  @@index([status])
  @@index([messageId])
}

// ===========================================================================
// PHASE 7 — internal team chat. Additive.
//
// Two conversation kinds share one table: direct messages (2+ members, no name)
// and project channels (named, bound to a Project). Membership is explicit so
// room authorization is a simple "is this user a member" check on both the REST
// and socket sides. `Message.clientNonce` is the reconnect-safety mechanism: the
// client stamps each send with a nonce, the unique index makes a re-send after a
// dropped ack a no-op instead of a duplicate.
// ===========================================================================

model Conversation {
  id        String   @id @default(uuid())
  type      String   @default("dm") // dm | channel
  name      String? // channel name; DMs derive their title from members
  projectId String? // set for a project channel
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ConversationMember[]
  messages Message[]
  project  Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

model ConversationMember {
  id             String    @id @default(uuid())
  conversationId String
  userId         String
  lastReadAt     DateTime? // everything at/before this is "read" — drives unread counts + receipts
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation("ConversationMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  body           String
  clientNonce    String? // idempotency key: a resend after a lost ack collides here
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([conversationId, clientNonce])
  @@index([conversationId, createdAt])
}

// ===========================================================================
// PHASE 2 — content models.
//
// ADDITIVE ONLY. New tables and new nullable/defaulted columns; nothing above
// this line is renamed or dropped, so the old backend keeps running against
// this schema and the nginx rollback stays real.
//
// Services and testimonials currently live nowhere: services are hardcoded in
// the frontend (changing one means a deploy) and testimonials are hardcoded in
// markup, which is how two fabricated quotes shipped. Both become records.
// ===========================================================================

model Service {
  id             String   @id @default(uuid())
  slug           String   @unique
  title          String
  summary        String
  body           String?
  icon           String?
  stack          String[]
  deliverables   String[]
  timeline       String?
  order          Int      @default(0)
  published      Boolean  @default(false)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  testimonials Testimonial[] @relation("ServiceTestimonials")

  @@index([published, order])
}

model Testimonial {
  id        String  @id @default(uuid())
  author    String
  role      String?
  company   String?
  quote     String
  avatarUrl String?

  // Provenance. The publish path requires BOTH of these to be non-null — that is
  // the structural guard against fabricated testimonials reaching the site again.
  // Enforced in the service layer, not just the UI.
  sourceUrl  String?
  verifiedAt DateTime?

  serviceId String?
  service   Service? @relation("ServiceTestimonials", fields: [serviceId], references: [id], onDelete: SetNull)

  order     Int      @default(0)
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, order])
}

model Industry {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  capability  String
  icon        String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, order])
}
