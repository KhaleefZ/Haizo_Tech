# Copy to .env for local development. Never commit real values.
NODE_ENV=development
PORT=5001

# Postgres. Use the SAME database the current production app uses only via a
# restored dump — never point local development at production.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/haizotech

# Must be >= 32 chars. Rotate by bumping User.tokenVersion.
JWT_SECRET=change-me-to-at-least-32-characters-long

# Separate key with aud:"visitor" so a public chat token can never be replayed
# as a staff token. Phase 8 — present here so deploys don't discover it late.
VISITOR_JWT_SECRET=change-me-to-a-different-32-char-secret

# Comma-separated. No wildcards: credentials:true forbids them anyway.
# LOCAL:
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# PRODUCTION (set on the VPS, do not use the localhost values above):
#   CORS_ORIGINS=https://haizotech.com,https://www.haizotech.com,https://admin.haizotech.com
#   COOKIE_DOMAIN=.haizotech.com
# All three apps share the registrable domain haizotech.com, which is what lets
# SameSite=Lax cookies work across them without dropping CSRF protection.

# Shared secret for the publish -> revalidate webhook (HMAC-SHA256).
REVALIDATE_SECRET=change-me
WEB_REVALIDATE_URL=http://localhost:3000/api/revalidate
#   PRODUCTION: WEB_REVALIDATE_URL=https://haizotech.com/api/revalidate

# Notification email + daily digest. All optional — with no SMTP_PASS the mailer
# is a logged no-op. For Gmail, SMTP_PASS must be an APP PASSWORD (2FA required).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=
MAIL_FROM=HaizoTech <you@gmail.com>
ADMIN_URL=http://localhost:3001

# Local-disk uploads. The app runs on a single VPS with persistent disk, so
# uploaded files are written under UPLOADS_DIR and served as static files at
# UPLOADS_PUBLIC_URL. UPLOADS_DIR may be relative (to the process cwd) or an
# absolute path such as a mounted volume.
UPLOADS_DIR=uploads
UPLOADS_PUBLIC_URL=http://localhost:5001/uploads
#   PRODUCTION (behind nginx on the VPS):
#     UPLOADS_DIR=/var/www/haizotech/uploads
#     UPLOADS_PUBLIC_URL=https://admin.haizotech.com/uploads
